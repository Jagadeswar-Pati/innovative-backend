# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=production
USE_HTTPS=true
DOMAIN=your-domain.com

# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET=your_jwt_secret
SESSION_SECRET=your_session_secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
ADMIN_ROLE=superadmin
ADMIN_IS_ACTIVE=true

# ============================================
# CORS & FRONTEND
# ============================================
# Comma-separated origins. For production (Render), add your live frontend URL, e.g. https://inovative-hub.com
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5176,http://localhost:8080
# Public URL of your frontend (no trailing slash). All email links (login, order, checkout, reset password) use this.
# On Render set to your live site, e.g. https://inovative-hub.com (or set DOMAIN=inovative-hub.com and NODE_ENV=production)
FRONTEND_URL=

# ============================================
# CLOUDINARY CONFIGURATION (Image Storage)
# ============================================
# Set in .env only (never commit real value). Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=

# ============================================
# PAYMENT GATEWAY - RAZORPAY
# ============================================
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ============================================
# SSL CERTIFICATE PATHS (Production)
# ============================================
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-backend-domain.com/auth/google/callback

# ============================================
# BREVO (Sendinblue)
# ============================================
BREVO_API_KEY=your_brevo_api_key

# ============================================
# SMTP (Gmail or other)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
SMTP_FROM=no-reply@your-domain.com
